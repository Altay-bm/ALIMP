        <mxCell id="uc7" value="Просмотреть список заявок" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="220" y="440" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="uc8" value="Просмотреть историю заявки" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="460" y="440" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="uc9" value="Управлять сотрудниками" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#EF4444;" vertex="1" parent="1">
          <mxGeometry x="220" y="520" width="200" height="60" as="geometry"/>
