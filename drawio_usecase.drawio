<mxfile host="app.diagrams.net">
  <diagram name="Use Case">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Actors -->
        <mxCell id="actor1" value="Менеджер" style="shape=umlActor;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="40" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="actor2" value="Инженер" style="shape=umlActor;html=1;" vertex="1" parent="1">
